[sub_resource type="GDScript" id="GDScript_i26rj"]
resource_name = "OnStartStop"
script/source = "extends Button

func _ready() -> void:
	_sync_label()

func _pressed() -> void:
	if WizardManager.is_window_open():
		WizardManager.close_window()
	else:
		var win := WizardManager.create_window()
		# Reset label if the user closes the window via the X button
		win.tree_exited.connect(_sync_label)
	_sync_label()

func _sync_label() -> void:
	text = \"Stop\" if WizardManager.is_window_open() else \"Start\"
"

[sub_resource type="GDScript" id="GDScript_settings"]
resource_name = "OnSettings"
script/source = "extends Button

const SettingsModal := preload(\"res://scenes/ui/SettingsModal.tscn\")

var _layer: CanvasLayer = null

func _pressed() -> void:
	if _layer != null:
		return
	_layer = CanvasLayer.new()
	_layer.layer = 128
	get_tree().root.get_child(0).add_child(_layer)
	var modal := SettingsModal.instantiate()
	modal.closed.connect(func():
		_layer.queue_free()
		_layer = null
	)
	_layer.add_child(modal)
"

[sub_resource type="GDScript" id="GDScript_kjwba"]
resource_name = "OnQuit"
script/source = "extends Button

func _pressed() -> void:
	get_tree().quit()
"

